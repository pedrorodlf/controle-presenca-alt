cat > .env.example << 'EOF'
# PostgreSQL Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=controle_presenca
DB_USER=presenca_user
DB_PASSWORD=presenca_pass

# Google Drive Backup (opcional)
GOOGLE_CREDENTIALS=credentials/service_account.json
GOOGLE_DRIVE_FOLDER_ID=
SYNC_ENABLED=false

# Backup Settings
BACKUP_RETENTION_DAYS=30
LOCAL_RETENTION_DAYS=7
BACKUP_SCHEDULE=23:00

# Application
DEBUG=false
LOG_LEVEL=INFO
EOF
